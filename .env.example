# Published Google Sheet CSV URL (File → Share → Publish to web → CSV)
# Copy to `.env` and adjust if needed (see .gitignore — .env is not committed)
QUESTIONS_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vR-a7YhVd3iyf9ULzUBrUdmWb8RE5TraIkE9FKYiI3N5oDdfKE4uWpAX4UFNvEJIqMbt4hP-bRPpQCz/pub?gid=0&single=true&output=csv

# Optional: comma-separated. Omit for all types.
# MATH = generated math; EN / ZH = CSV MCQ rows with language EN or ZH (language column, or type column EN/ZH)
# Examples: MATH | EN | ZH | MATH,EN | MATH,EN,ZH
ALLOWED_QUESTION_TYPE=MATH,EN,ZH
